# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
# Required (not '*') when DJANGO_DEBUG=false; the app fails fast otherwise.
DJANGO_ALLOWED_HOSTS=*
DATABASE_URL=

# Production security (effective when DJANGO_DEBUG=false; TLS terminates at the proxy)
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000

# API behavior
# API_PAGE_SIZE=50
# THROTTLE_ANON=60/min
# THROTTLE_USER=600/min
# THROTTLE_SEC=20/min            # SEC-hitting actions (sync/ingest/bulk/resolve)

# Container
# GUNICORN_WORKERS=2

# Docker Compose Postgres (override in production)
# POSTGRES_USER=fredgar
# POSTGRES_PASSWORD=fredgar
# POSTGRES_DB=fredgar

# SEC / EDGAR (required for data.sec.gov)
USER_AGENT_EMAIL=your-email@example.com
# Optional: pause between CRM→EDGAR bulk sync requests (see sync_crm_matched_edgar)
# SEC_SYNC_DELAY_SECONDS=0.25
# SEC_SYNC_DELAY_AFTER_FACTS_SECONDS=0.35

# Optional: override filing download directory (default: ../data from src/)
# EDGAR_DATA_DIR=/absolute/path/to/data

# Public data (FRED — https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# CORS (comma-separated origins for the Vite dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Background jobs (Celery). ALWAYS_EAGER runs tasks inline (no broker needed).
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_TASK_ALWAYS_EAGER=false

# Filing artifact storage (content-addressed by SHA-1)
# STORAGE_BACKEND=local            # local | s3
# STORAGE_ROOT=                    # defaults to <EDGAR_DATA_DIR>/storage

# Content extraction (PDF/other) via an Apache Tika server sidecar
# ENABLE_TIKA=false
# TIKA_SERVER_ENDPOINT=http://localhost:9998

# Embeddings for ContentChunk retrieval (off by default; schema works regardless)
# ENABLE_EMBEDDINGS=false
# EMBEDDINGS_BACKEND=none          # none | local | api

# AI narrative analysis of leadership (grounded in SEC filing text). Enabled by default
# with Claude as the provider; it degrades to a no-op unless the optional SDK + a credential
# are present (`pip install -r requirements-ai.txt`). See docs/leadership-methodology.md.
# ENABLE_AI_ANALYSIS=true          # default true; set false to disable
# AI_ANALYSIS_BACKEND=anthropic    # anthropic | none
# AI_ANALYSIS_MODEL=claude-opus-4-8
# Credential — token preferred, API key fallback. Set ONLY ONE (both -> 401).
# CLAUDE_CODE_OAUTH_TOKEN=         # from `claude setup-token` (Bearer auth; preferred)
# ANTHROPIC_API_KEY=               # fallback (metered API key)

# Logging
LOG_LEVEL=INFO
